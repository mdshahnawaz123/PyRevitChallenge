<Window x:Class="PyRevitChallenge.UI.WorksetGrabber"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workset Grabber" Height="450" Width="650">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Workset Label -->
        <Label Content="Select Worksets:" 
               FontWeight="Bold"
               Grid.Row="0" Grid.Column="0"
               Margin="0,0,0,5"/>

        <!-- Workset List -->
        <ListView x:Name="WorksetList"
                  Grid.Row="1" Grid.Column="0"
                  Margin="0,0,10,0"
                  SelectionMode="Extended"/>

        <!-- Options Panel -->
        <GroupBox Header="Options"
                  Grid.Row="0" Grid.Column="1"
                  Grid.RowSpan="2"
                  Margin="5">

            <StackPanel Margin="10">

                <CheckBox Content="Select Only Visible Elements"
                          Margin="0,5" IsChecked="False"/>

                <CheckBox Content="Include Elements In Linked Models"
                          Margin="0,5" IsChecked="False"/>

                <CheckBox Content="Zoom To Selected Elements"
                          Margin="0,5" IsChecked="False"/>

            </StackPanel>

        </GroupBox>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <Button Content="Select Elements"
                    Width="120"
                    Height="30"
                    Margin="5"/>

            <Button Content="Cancel"
                    Width="80"
                    Height="30"
                    Margin="5"/>

        </StackPanel>

    </Grid>

</Window>