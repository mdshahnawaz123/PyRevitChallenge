<Window x:Class="PyRevitChallenge.UI.Crash_n_Clasher"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Digital Design"
        Height="400" Width="610"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <Label Grid.Row="0" 
           Grid.ColumnSpan="2"
           Content="Crash n Clasher"
           HorizontalContentAlignment="Center"
           FontSize="16"
           FontStyle="Italic"
           FontWeight="Bold"
           Margin="0,0,0,10"/>

        <!-- Left Panel -->
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">

            <Label Content="Select 1st Category"
               FontSize="14"
               FontStyle="Italic"
               FontWeight="Bold"/>
            <ComboBox Name="Category01" Margin="0,0,0,10" DisplayMemberPath="Name"/>

            <Label Content="Select 2nd Category"
               FontSize="14"
               FontStyle="Italic"
               FontWeight="Bold"/>
            <ComboBox Name="Category02" Margin="0,0,0,10" DisplayMemberPath="Name"/>

            <GroupBox Header="Model Selection" Margin="0,10,0,10">
                <StackPanel>
                    <CheckBox Content="Host Model" Name="HostCheckbox"/>
                    <CheckBox Content="Linked Model" Name="LinkedCheckbox"/>
                </StackPanel>
            </GroupBox>

            <Button Content="Hit to Check"
                Click="Btn_Crash"
                Margin="0,10,0,0"
                Padding="5"/>
            <Button Content="Export CSV"
                    Click="Btn_Export"
                    Margin="0,10,0,0"
                    Padding="5"/>
        </StackPanel>

        <!-- Right Panel -->
        <ListView Grid.Row="1" Grid.Column="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ElementID" 
                                DisplayMemberBinding="{Binding Id}" Width="80"/>
                    <GridViewColumn Header="Element Name 01" 
                                DisplayMemberBinding="{Binding Name1}" Width="150"/>
                    <GridViewColumn Header="Element Name 02" 
                                DisplayMemberBinding="{Binding Name2}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>

    </Grid>
</Window>