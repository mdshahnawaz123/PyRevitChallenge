<Window x:Class="PyRevitChallenge.UI.FloorifyMyRooms"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PyRevitChallenge.UI" 
             Height="250" Width="400" Title="BIM Digital Design ">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Title -->
        <Label Grid.Row="0" Content="Floorify My Rooms" FontSize="18" FontWeight="Bold" HorizontalContentAlignment="Center" Margin="0,0,0,20"/>
        <!-- Middle Space -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <Button Click="btnSelectRooms" Content="Hit For Select Room" Height="40" Margin="10" Background="Beige"/>
            <Button Click="btnFloorify" Content="Hit For Floorify" Height="40" Margin="10" Background="Beige"/>
        </StackPanel>
    </Grid>
</Window>
