<Window x:Class="PyRevitChallenge.UI.ClickCounter"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="400" Width="350"
        Title="BIM Digital Design">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0"
               Content="Click Counter"
               FontSize="16"
               HorizontalContentAlignment="Center"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1">

            <Label Content="Select Category"/>
            <ComboBox Name="CatComb" Margin="0,5,0,10" DisplayMemberPath="Name"
                      SelectionChanged="categorySelection"/>

            <Label Content="Select Parameter"/>
            <ComboBox Name="ParamComb" Margin="0,5,0,10"/>

            <Label Content="Enter Prefix"/>
            <TextBox Name="TBPrefix" Margin="0,5,0,10"/>

            <Label Content="Enter Start Number for Increment (Default: 01)"/>
            <TextBox Name="TBStart" Margin="0,5,0,10" Text="01"/>

            <TextBlock Name="ClickCounterPreviews"
                       Margin="0,10"
                       FontWeight="Bold"
                       Foreground="DarkBlue"/>

        </StackPanel>

        <Button Grid.Row="2"
                Content="Click Counter"
                Height="30"
                Width="140"
                HorizontalAlignment="Center"
                Margin="10"
                Click="BtnClickCount"/>

    </Grid>
</Window>